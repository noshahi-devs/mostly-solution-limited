<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=0"/>
    <title>About Us | Mostly Solution Limited</title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet" />
    
    <!-- Scripts -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#1B75BC', // Logo Blue
                        secondary: '#8DC63F', // Logo Green
                        accent: '#00AEEF', // Logo Cyan
                        background: '#111111', // Black
                        muted: '#F8F9FA', // Light Gray
                        card: '#FFFFFF',
                        foreground: '#111111',
                    },
                    fontFamily: {
                        sans: ['Outfit', 'sans-serif'],
                    },
                }
            }
        }
    </script>
    <style>
        scroll-behavior: smooth;
    </style>
</head>
<body class="bg-white text-foreground font-sans overflow-x-hidden">

    <!-- Top Bar -->
    <div class="bg-[#111111] text-white py-2 text-sm">
        <div class="max-w-6xl mx-auto px-5 flex justify-between items-center">
            <div class="flex gap-6">
                <a href="tel:09137645289" class="flex items-center gap-1 hover:text-primary transition-colors">
                    <i data-lucide="phone" class="w-4 h-4"></i> Nigeria: 0913 764 5289
                </a>
            </div>
            <a href="mailto:info@29workshop.com" class="flex items-center gap-1 hover:text-primary transition-colors">
                <i data-lucide="mail" class="w-4 h-4"></i> info@29workshop.com
            </a>
        </div>
    </div>

    <!-- Header -->
    <header class="sticky top-0 z-50 bg-white shadow-sm h-20 flex items-center">
        <div class="max-w-6xl w-full mx-auto px-5 flex justify-between items-center">
            <a href="index.html" class="flex items-center gap-3">
                <img src="img/NTB logo.jpeg" alt="Mostly Solutions" class="h-12">
                <span class="font-extrabold text-2xl tracking-tighter text-[#111111] hidden sm:block">Mostly Solution Limited</span>
            </a>
            
            <nav class="hidden lg:flex items-center gap-8 font-semibold uppercase text-xs tracking-wider">
                <a href="index.html" class="hover:text-primary transition-colors">Home</a>
                <a href="about.html" class="text-primary font-black border-b-2 border-primary transition-colors">About Us</a>
                <a href="index.html#services" class="hover:text-primary transition-colors">Services</a>
                <a href="index.html#locations" class="hover:text-primary transition-colors">Locations</a>
                <a href="index.html#appointment" class="bg-primary text-white px-5 py-2 rounded-md hover:bg-black transition-all">Book Now</a>
            </nav>

            <button class="lg:hidden text-[#111111]" onclick="document.getElementById('mobile-menu').classList.toggle('hidden')">
                <i data-lucide="menu" class="w-8 h-8"></i>
            </button>
        </div>
        
        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden fixed inset-0 z-[60] bg-white flex flex-col p-8 gap-8 uppercase font-bold text-lg">
            <div class="flex justify-between items-center">
                <img src="img/NTB logo.jpeg" alt="Logo" class="h-10">
                <button onclick="document.getElementById('mobile-menu').classList.add('hidden')">
                    <i data-lucide="x" class="w-8 h-8"></i>
                </button>
            </div>
            <a href="index.html">Home</a>
            <a href="about.html" class="text-primary">About Us</a>
            <a href="index.html#services">Services</a>
            <a href="#appointment">Book Now</a>
        </div>
    </header>

    <main class="mt-16">
        <!-- Intro Section -->
        <div class="w-full max-w-6xl mx-auto px-4 py-16">
            <div class="grid gap-8 md:grid-cols-2 md:gap-12 items-center">
                <div class="relative">
                    <img src="https://images.unsplash.com/photo-1625047509168-a7026f36fe04?auto=format&fit=crop&q=80&w=1200" alt="Mobile auto-repair service" class="rounded-2xl h-[400px] lg:h-[550px] w-full object-cover shadow-2xl">
                    <div class="absolute -bottom-6 -right-6 bg-primary text-white p-8 rounded-2xl shadow-2xl hidden lg:block">
                        <div class="text-5xl font-black mb-1 italic">25+</div>
                        <div class="text-sm font-bold uppercase tracking-widest">States Covered</div>
                    </div>
                </div>
                <div class="space-y-8">
                    <div class="inline-flex items-center bg-secondary/10 border border-secondary/20 rounded-full px-4 py-2">
                        <span class="text-secondary text-sm font-black uppercase tracking-widest italic">Our Identity</span>
                    </div>
                    <h2 class="text-4xl md:text-6xl font-black text-[#111111] leading-tight uppercase italic">
                        <span class="text-primary italic">MOBILE MECHANIC</span> SERVICE
                    </h2>
                    <p class="text-gray-600 text-lg font-medium leading-relaxed">
                        Mostly Solution Limited provides comprehensive mobile auto-repair and maintenance services. Our team of skilled technicians is equipped to handle vehicle inspections, diagnostics, repairs, and road rescue operations at your location.
                    </p>
                    <p class="text-gray-600 text-lg font-medium leading-relaxed">
                        We leverage advanced technology and a dedicated team of professionals to deliver high-quality, reliable, and convenient auto repair solutions. Our mission is to minimize downtime and ensure your vehicle is always in top condition.
                    </p>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 pt-4">
                        <div class="flex items-center gap-3 text-lg font-bold text-[#111111]">
                            <div class="bg-secondary/10 p-2 rounded-lg"><i data-lucide="check" class="text-secondary w-6 h-6"></i></div>
                            24/7 Mobile Support
                        </div>
                        <div class="flex items-center gap-3 text-lg font-bold text-[#111111]">
                            <div class="bg-secondary/10 p-2 rounded-lg"><i data-lucide="clock" class="text-secondary w-6 h-6"></i></div>
                            Quick Turnaround
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Vision/Mission Section -->
        <section class="py-24 bg-gray-50 border-y border-gray-100">
            <div class="w-full max-w-6xl mx-auto px-4 md:px-6">
                <div class="text-center mb-20">
                    <h2 class="text-4xl md:text-5xl font-black italic uppercase leading-tight">
                        WE ARE <span class="text-primary italic">THE LEADING MOBILE MECHANIC</span><br>SERVICE PROVIDER.
                    </h2>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-24">
                    <!-- Card 1 -->
                    <div class="bg-white p-10 rounded-3xl shadow-xl hover:shadow-2xl transition-all duration-300 border border-gray-100 group">
                        <div class="bg-secondary text-white w-16 h-16 rounded-2xl flex items-center justify-center mb-8 shadow-xl shadow-secondary/20 group-hover:rotate-6 transition-transform">
                            <i data-lucide="telescope" class="w-8 h-8"></i>
                        </div>
                        <h3 class="text-2xl font-black uppercase italic mb-6">Our Vision</h3>
                        <p class="text-gray-500 font-medium leading-relaxed">To be the leading innovator in automotive care, setting new standards for excellence and customer satisfaction across the industry.</p>
                    </div>
                    <!-- Card 2 -->
                    <div class="bg-white p-10 rounded-3xl shadow-xl hover:shadow-2xl transition-all duration-300 border border-gray-100 group">
                        <div class="bg-secondary text-white w-16 h-16 rounded-2xl flex items-center justify-center mb-8 shadow-xl shadow-secondary/20 group-hover:rotate-6 transition-transform">
                            <i data-lucide="target" class="w-8 h-8"></i>
                        </div>
                        <h3 class="text-2xl font-black uppercase italic mb-6">Our Mission</h3>
                        <p class="text-gray-500 font-medium leading-relaxed">Our mission is to deliver high-quality, reliable, and convenient auto repair and maintenance solutions through the integration of technology and skilled expertise.</p>
                    </div>
                    <!-- Card 3 -->
                    <div class="bg-white p-10 rounded-3xl shadow-xl hover:shadow-2xl transition-all duration-300 border border-gray-100 group">
                        <div class="bg-secondary text-white w-16 h-16 rounded-2xl flex items-center justify-center mb-8 shadow-xl shadow-secondary/20 group-hover:rotate-6 transition-transform">
                            <i data-lucide="heart" class="w-8 h-8"></i>
                        </div>
                        <h3 class="text-2xl font-black uppercase italic mb-6">Core Values</h3>
                        <p class="text-gray-500 font-medium leading-relaxed">Integrity, Excellence, Innovation, Customer-Centric, Teamwork, Environmental Responsibility.</p>
                    </div>
                </div>

                <!-- Convenience Section -->
                <div class="grid gap-16 md:grid-cols-2 items-center">
                    <div class="space-y-8">
                        <h3 class="text-3xl font-black uppercase italic tracking-tight">WE MAKE AUTO REPAIR MORE<br><span class="text-primary italic">CONVENIENT AND EFFICIENT</span></h3>
                        <p class="text-gray-600 text-lg font-medium leading-relaxed">
                            Mostly Solution Limited is building the largest African mobile auto-repair network, providing comprehensive auto services driven by technology. We offer vehicle inspections, diagnostics, repairs, and road rescue operations at your location.
                        </p>
                        <div class="space-y-8 pt-4">
                            <div class="space-y-3">
                                <div class="flex justify-between font-black uppercase text-xs tracking-[.2em]"><span>Customer Satisfaction</span><span>95%</span></div>
                                <div class="h-3 rounded-full bg-gray-200 overflow-hidden shadow-inner">
                                    <div class="h-full w-[95%] bg-secondary shadow-lg shadow-secondary/40"></div>
                                </div>
                            </div>
                            <div class="space-y-3">
                                <div class="flex justify-between font-black uppercase text-xs tracking-[.2em]"><span>Service Efficiency</span><span>90%</span></div>
                                <div class="h-3 rounded-full bg-gray-200 overflow-hidden shadow-inner">
                                    <div class="h-full w-[90%] bg-secondary shadow-lg shadow-secondary/40"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="relative h-[450px] group">
                        <img src="img/about_team.png" alt="Our Team" class="rounded-3xl object-cover w-full h-full shadow-2xl transition-transform duration-700 group-hover:scale-105">
                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent rounded-3xl flex items-end p-8">
                            <div class="text-white">
                                <p class="text-primary font-black uppercase tracking-widest mb-1 italic">Our Experts</p>
                                <h4 class="text-2xl font-black italic uppercase">Certified Professionals</h4>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Stats Section -->
        <section class="py-24">
            <div class="w-full max-w-6xl mx-auto px-4">
                <div class="grid gap-12 grid-cols-2 lg:grid-cols-4 mb-32">
                    <div class="text-center group">
                        <div class="text-5xl font-black text-primary italic mb-2 group-hover:scale-110 transition-transform">25+</div>
                        <div class="text-xs font-black uppercase text-gray-500 tracking-[.3em]">States Covered</div>
                    </div>
                    <div class="text-center group">
                        <div class="text-5xl font-black text-primary italic mb-2 group-hover:scale-110 transition-transform">1000+</div>
                        <div class="text-xs font-black uppercase text-gray-500 tracking-[.3em]">Vehicles Serviced</div>
                    </div>
                    <div class="text-center group">
                        <div class="text-5xl font-black text-primary italic mb-2 group-hover:scale-110 transition-transform">95%</div>
                        <div class="text-xs font-black uppercase text-gray-500 tracking-[.3em]">Satisfaction Rate</div>
                    </div>
                    <div class="text-center group">
                        <div class="text-5xl font-black text-primary italic mb-2 group-hover:scale-110 transition-transform">50+</div>
                        <div class="text-xs font-black uppercase text-gray-500 tracking-[.3em]">Partner Workshops</div>
                    </div>
                </div>

                <!-- Services Grid -->
                <div class="mb-32">
                    <h2 class="mb-16 text-4xl font-black italic uppercase text-center md:text-left">OUR <span class="text-primary italic">SERVICES.</span></h2>
                    <div class="grid gap-6 grid-cols-2 lg:grid-cols-4">
                        <!-- Service items -->
                        <div class="group rounded-2xl bg-gray-50 p-8 transition-all hover:bg-primary shadow-sm hover:shadow-xl hover:-translate-y-1">
                            <div class="mb-5 text-primary group-hover:text-white transition-colors">
                                <i data-lucide="settings" class="w-10 h-10"></i>
                            </div>
                            <h3 class="text-lg font-black uppercase italic group-hover:text-white transition-colors">Comprehensive Inspections</h3>
                        </div>
                        <div class="group rounded-2xl bg-gray-50 p-8 transition-all hover:bg-primary shadow-sm hover:shadow-xl hover:-translate-y-1">
                            <div class="mb-5 text-primary group-hover:text-white transition-colors">
                                <i data-lucide="pen-tool" class="w-10 h-10"></i>
                            </div>
                            <h3 class="text-lg font-black uppercase italic group-hover:text-white transition-colors">Minor Repairs</h3>
                        </div>
                        <div class="group rounded-2xl bg-gray-50 p-8 transition-all hover:bg-primary shadow-sm hover:shadow-xl hover:-translate-y-1">
                            <div class="mb-5 text-primary group-hover:text-white transition-colors">
                                <i data-lucide="car" class="w-10 h-10"></i>
                            </div>
                            <h3 class="text-lg font-black uppercase italic group-hover:text-white transition-colors">Major Repairs</h3>
                        </div>
                        <div class="group rounded-2xl bg-gray-50 p-8 transition-all hover:bg-primary shadow-sm hover:shadow-xl hover:-translate-y-1">
                            <div class="mb-5 text-primary group-hover:text-white transition-colors">
                                <i data-lucide="cog" class="w-10 h-10"></i>
                            </div>
                            <h3 class="text-lg font-black uppercase italic group-hover:text-white transition-colors">Annual Maintenance</h3>
                        </div>
                        <div class="group rounded-2xl bg-gray-50 p-8 transition-all hover:bg-primary shadow-sm hover:shadow-xl hover:-translate-y-1">
                            <div class="mb-5 text-primary group-hover:text-white transition-colors">
                                <i data-lucide="battery" class="w-10 h-10"></i>
                            </div>
                            <h3 class="text-lg font-black uppercase italic group-hover:text-white transition-colors">Roadside Assistance</h3>
                        </div>
                        <div class="group rounded-2xl bg-gray-50 p-8 transition-all hover:bg-primary shadow-sm hover:shadow-xl hover:-translate-y-1">
                            <div class="mb-5 text-primary group-hover:text-white transition-colors">
                                <i data-lucide="wrench" class="w-10 h-10"></i>
                            </div>
                            <h3 class="text-lg font-black uppercase italic group-hover:text-white transition-colors">Vehicle Upgrades</h3>
                        </div>
                        <div class="group rounded-2xl bg-gray-50 p-8 transition-all hover:bg-primary shadow-sm hover:shadow-xl hover:-translate-y-1">
                            <div class="mb-5 text-primary group-hover:text-white transition-colors">
                                <i data-lucide="fuel" class="w-10 h-10"></i>
                            </div>
                            <h3 class="text-lg font-black uppercase italic group-hover:text-white transition-colors">Engine Diagnostics</h3>
                        </div>
                        <div class="group rounded-2xl bg-gray-50 p-8 transition-all hover:bg-primary shadow-sm hover:shadow-xl hover:-translate-y-1">
                            <div class="mb-5 text-primary group-hover:text-white transition-colors">
                                <i data-lucide="timer" class="w-10 h-10"></i>
                            </div>
                            <h3 class="text-lg font-black uppercase italic group-hover:text-white transition-colors">Tire Services</h3>
                        </div>
                    </div>
                </div>

                <!-- Recent Work Gallery -->
                <div class="pb-24">
                    <h2 class="mb-16 text-4xl font-black italic uppercase text-center md:text-left">OUR <span class="text-primary italic">RECENT WORK.</span></h2>
                    <div class="grid gap-6 grid-cols-1 md:grid-cols-2">
                        <div class="relative h-[350px] overflow-hidden rounded-3xl group shadow-xl">
                            <img src="https://images.unsplash.com/photo-1530046339160-ce3e5b0c7a2f?auto=format&fit=crop&q=80&w=1200" alt="Recent work 1" class="object-cover w-full h-full transition-transform duration-700 group-hover:scale-110">
                            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                                <div class="bg-primary text-white p-4 rounded-full"><i data-lucide="maximize" class="w-8 h-8"></i></div>
                            </div>
                        </div>
                        <div class="relative h-[350px] overflow-hidden rounded-3xl group shadow-xl">
                            <img src="https://images.unsplash.com/photo-1544724569-5f546fd6f2b5?auto=format&fit=crop&q=80&w=1200" alt="Recent work 2" class="object-cover w-full h-full transition-transform duration-700 group-hover:scale-110">
                            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                                <div class="bg-primary text-white p-4 rounded-full"><i data-lucide="maximize" class="w-8 h-8"></i></div>
                            </div>
                        </div>
                        <div class="relative h-[350px] overflow-hidden rounded-3xl group shadow-xl">
                            <img src="https://images.unsplash.com/photo-1517026575980-3e1e2dedeab4?auto=format&fit=crop&q=80&w=1200" alt="Recent work 3" class="object-cover w-full h-full transition-transform duration-700 group-hover:scale-110">
                            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                                <div class="bg-primary text-white p-4 rounded-full"><i data-lucide="maximize" class="w-8 h-8"></i></div>
                            </div>
                        </div>
                        <div class="relative h-[350px] overflow-hidden rounded-3xl group shadow-xl">
                            <img src="https://images.unsplash.com/photo-1504222490345-c075b6008014?auto=format&fit=crop&q=80&w=1200" alt="Recent work 4" class="object-cover w-full h-full transition-transform duration-700 group-hover:scale-110">
                            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                                <div class="bg-primary text-white p-4 rounded-full"><i data-lucide="maximize" class="w-8 h-8"></i></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Final CTA -->
        <div class="my-10 bg-[#111111] p-16 lg:p-32 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-64 h-64 bg-primary opacity-5 rounded-full -ml-32 -mt-32"></div>
            <div class="w-full max-w-6xl mx-auto flex flex-col items-center justify-between gap-12 relative z-10 text-center">
                <div class="max-w-3xl space-y-6">
                    <h3 class="text-4xl md:text-6xl font-black text-white leading-tight italic uppercase italic">Schedule An <span class="text-primary italic">Appointment</span></h3>
                    <p class="text-gray-400 text-lg md:text-xl font-medium leading-relaxed uppercase tracking-tight">Book your appointment with Mostly Solution Limited today and let us take care of your vehicle. Our mobile team is ready to serve you at your location.</p>
                </div>
                <a href="index.html#appointment">
                    <button class="bg-primary text-white px-12 py-5 rounded-full font-black uppercase tracking-[.2em] text-xl hover:bg-white hover:text-black transition-all shadow-2xl shadow-primary/20 italic">Book Appointment</button>
                </a>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-[#111111] text-white py-24 border-t border-white/5">
        <div class="max-w-6xl mx-auto px-5">
            <div class="grid lg:grid-cols-4 gap-16">
                <div>
                    <div class="flex items-center gap-4 mb-10">
                        <img src="img/NTB logo.jpeg" alt="Logo" class="h-10 brightness-0 invert">
                        <span class="text-2xl font-black italic tracking-tighter uppercase">Mostly Solution Limited</span>
                    </div>
                    <p class="text-gray-500 font-bold uppercase text-[10px] tracking-widest leading-relaxed">Mostly Solutions Limited. Premium automotive mobile engineering across Nigeria and the UK.</p>
                </div>
                <div>
                    <h4 class="text-lg font-black uppercase italic mb-10 border-l-4 border-primary pl-4 tracking-[3px]">Menu</h4>
                    <div class="flex flex-col gap-5 text-gray-500 font-black uppercase text-[10px] tracking-widest">
                        <a href="index.html" class="hover:text-primary transition-colors">Home</a>
                        <a href="about.html" class="text-primary transition-colors">About</a>
                        <a href="index.html#services" class="hover:text-primary transition-colors">Services</a>
                        <a href="index.html#appointment" class="hover:text-primary transition-colors">Booking</a>
                    </div>
                </div>
                <div>
                    <h4 class="text-lg font-black uppercase italic mb-10 border-l-4 border-primary pl-4 tracking-[3px]">Lagos</h4>
                    <p class="text-gray-500 font-black uppercase text-[10px] tracking-widest leading-loose mb-4">8 Ramat Crescent, Ogudu G.R.A.</p>
                    <a href="tel:09137645289" class="text-white font-black uppercase text-xs tracking-widest">📞 0913 764 5289</a>
                </div>
                <div>
                    <h4 class="text-lg font-black uppercase italic mb-10 border-l-4 border-primary pl-4 tracking-[3px]">Luton</h4>
                    <p class="text-gray-500 font-black uppercase text-[10px] tracking-widest leading-loose mb-4">145 Ashburnham Road, Luton</p>
                    <a href="tel:+447760749992" class="text-white font-black uppercase text-xs tracking-widest">📞 +44 7760 749992</a>
                </div>
            </div>
            <div class="mt-20 pt-10 border-t border-white/10 text-center text-gray-700 font-black uppercase text-[9px] tracking-[5px]">
                &copy; 2026 Mostly Solution Limited
            </div>
        </div>
    </footer>

